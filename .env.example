# ICTM-Trainer backend configuration.
# Copy to .env and adjust for your environment. Loaded by config.py (python-dotenv).
# Both default to ../il-math-problem-bank relative to the repo, so local dev needs no .env.

# Path to the problem bank SQLite database (read-only).
# PROBLEM_BANK_DB=../il-math-problem-bank/problems.db

# Directory holding the diagram images served at /api/images/<file>.
# PROBLEM_BANK_IMAGES=../il-math-problem-bank/images
