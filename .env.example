# ICTM-Trainer backend configuration.
# Copy to .env and adjust for your environment. Loaded by config.py (python-dotenv).
# Both default to ../il-math-problem-bank relative to the repo, so local dev needs no .env.

# Path to the problem bank SQLite database (read-only).
# PROBLEM_BANK_DB=../il-math-problem-bank/problems.db

# Directory holding the diagram images served at /api/images/<file>.
# PROBLEM_BANK_IMAGES=../il-math-problem-bank/images

# URL prefix for diagram images. Defaults to the Flask route, which is fine for
# local dev. For production, run `python scripts/stage_images.py` and set this to
# /images so the CDN serves them instead of a Python function.
# IMAGE_BASE_URL=/images

# --- Accounts & stats (optional) ------------------------------------------
# Leave these unset to run the trainer without accounts: practice still works,
# and /api/stats/* simply returns 401. Set both to enable sign-in and stats.
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server-side only, never ship to the client

# The frontend (Vite) reads these from ictm-reader/.env — note the anon key,
# NOT the service-role key:
#   VITE_SUPABASE_URL=https://<project>.supabase.co
#   VITE_SUPABASE_ANON_KEY=<anon-key>
